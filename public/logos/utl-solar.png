	function saveRespondTime() {

		var name = $("#customername").val();
		//var city = $("#city").val();
		var pincode = jQuery("#pincode").val();
		var duration = $("#duration").val();
		var country = $("#country").val();
		var mobile = $("#telephone").val();
		mobile = mobile.replace(/[^0-9]/g, '');
		var email = $("#email").val();
		var otp = $("#otp").val();
		var message = $("#message").val();
		var fixed_otp = '12345';
		if (name == '') {

			swal("", "Please Enter Name!", "error");
			return false;
		} else if (mobile == '') {
			//  alert('Please enter mobile no.');
			swal("", "Please Enter Mobile No.", "error");
			return false;
		} else if (mobile.length < 10) {
			swal("", "Mobile number must be min 10 digit", "error");
			return false;
		}
		//else if (city == '') {
		//  alert('Please enter city');
		//swal("", "Please Enter City!", "error");
		//	return false;
		//}
		else if (pincode == '') {
			swal("", "Please Enter Pincode!", "error");
			return false;
		} else if (pincode.length != 6) {
			swal("", "Pincode must be of 6 digit number", "error");
			return false;
		} else if (duration == '') {
			//  alert('Please enter city');
			swal("", "Please Enter Duration!", "error");
			return false;
		} else {
			document.getElementById("customersend").disabled = true;
			var isGoogleAds = 0;
			if ('' != '') {
				isGoogleAds = 1;
			}
			$.ajax({
				url: 'https://www.upsinverter.com/utl/wp-content/themes/astra/connect.php',
				data: {
					'mode': 'onlyshoppeTv',
					'name': name,
					'email': email,
					'country': country,
					'mobile': mobile,
					'message': message,
					'otp': otp,
					//'city': city,
					'pincode': pincode,
					'duration': duration,
					'enquiryPage': 'Enquiry',
					'gclid_field': $('#gclid_field').val(),
					'pageurl': 'http://www.upsinverter.com/utl/',
					'isGoogleAds': isGoogleAds
				},
				type: 'POST',
				dataType: 'JSON',
			}).done(function(data) {
				if (data.RESULT == "DONE") {
					//alert('Form has been inseted successfully');
                                          // Push event before the redirect
                                                var mobile_with_country_code=mobile;
                                                if(mobile_with_country_code.length==10)
                                                {
                                                  mobile_with_country_code='+91'+mobile_with_country_code;
                                                 }
                                             dataLayer = window.dataLayer || [];
                                             dataLayer.push({
                                              event: 'formSubmitted',
                                              leadsUserData: {
                                              phone_number: mobile_with_country_code,
                                               },
                                           });
					swal("Success", "Details have been Shared", "success");

       			    const formData = new FormData();
                    formData.append('Name', name);
        			formData.append('Pincode', pincode);
                    formData.append('Phone_Number', mobile);
        			formData.append('Customer_Type', 'unknown');

        			fetch('https://api.prd.swz-infra.net/chatbot-service/api/insert-form-offgrid', {
            			method: 'POST',
                		body: formData,
        			})
	               .then(response => response.json())
            			.then(data => {
                        console.log('Success:', data);
	        		        setTimeout(function() {
	                    			window.location = "https://www.upsinverter.com/utl/thank-you-page/";
	                		}, 3000);
                			$("#dealerform")[0].reset();
            			})
        			.catch(error => {
            			console.error('Error:', error);
   					});
					
					//window.location="https://www.upsinverter.com/search-dealer-location-list.php";
				} else {
					swal("Error", "Please Try Again Later", "error");
				}
			}).fail(function(response) {
				console.log("FAIL");
				console.log(response);
			});
		}
	}
