				</div>

				<div class="form-group">
					<div class="selectcont1" style="">
						<select id="duration" name="duration" class="chosen" required="required" autocomplete="new-duration">
							<option value="">---When you want to buy?---</option>
							<option value="4">Information Only</option>
							<option value="1">Within 15 Days</option>
							<option value="2">15 to 30 days</option>
							<option value="3">After 30 Days</option>

						</select>
					</div>
				</div>
